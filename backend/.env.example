# ============================
# MedDesk Backend Environment
# ============================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/meddesk_db"

# JWT Auth
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRY="7d"

# Twilio (WhatsApp / SMS)
# Leave blank in dev mode - OTPs will be logged to console
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_WHATSAPP_NUMBER=""

# OpenAI (AI Assistant)
# Leave blank to disable AI features in dev
OPENAI_API_KEY=""

# App Config
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Clinic Defaults (used for seed)
CLINIC_NAME="MedDesk Clinic"
CLINIC_PHONE="+919000000000"
WORKING_HOUR_START="09:00"
WORKING_HOUR_END="18:00"
SLOT_DURATION_MINUTES=30
CONSULTATION_FEE=500
